#!/usr/bin/env bash

# Count first-parent commits after the **next-release** marker tag only.
#
# `tag-release` (mode `both`): **release** tag is `vX.Y.Z.W` on the release commit; an empty
# commit follows; **start of next release** is a **bare** tag `X.Y.Z.(W+1)` (no `v`) on that empty
# commit. Build numbers must count from **that bare tag only**, never from the `v…` release tag.
#
# Implementation: `git describe --first-parent --tags --abbrev=0 --match '[0-9]*…'` matches only
# bare semver tags, so the pretag on HEAD is the anchor while `vX.Y.Z.W` on the parent is ignored.
# `git rev-list --first-parent --count "${base_tag}..HEAD"` counts commits strictly after that tag.
#
# If no bare tag exists yet (e.g. `release-only`), fall back to `--match 'v[0-9]*…'` so the release
# tag still produces a sensible count until the bare next-release tag is created.
#
# See build/README-VERSIONING.md.
# Only for master or hotfix/* branches; otherwise return 1.

branch="$(git branch --show-current)"

# If detached HEAD, try to find branch from remote
if [[ -z "$branch" ]]; then
    branch="$(git branch -r --contains HEAD | grep -v HEAD | head -1 |
        sed -e 's/origin\///' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
fi

# Only calculate build number for master or hotfix/* branches
if [[ "$branch" != "master" && ! "$branch" =~ ^hotfix/ ]]; then
    echo "1"
    exit 0
fi

# Nearest semver tag on first-parent (--abbrev=0 => tag name only). After a
# normal tag-release `both` run this is the bare pre-release tag on the empty commit.
base_tag=$(git describe --first-parent --tags --abbrev=0 --match '[0-9]*.[0-9]*.[0-9]*.[0-9]*' 2>/dev/null) || true
if [[ -z "$base_tag" ]]; then
    base_tag=$(git describe --first-parent --tags --abbrev=0 --match 'v[0-9]*.[0-9]*.[0-9]*.[0-9]*' 2>/dev/null) || true
fi

if [[ -n "$base_tag" ]]; then
    build_number=$(git rev-list --first-parent --count "${base_tag}..HEAD")
else
    build_number=1
fi

echo "$build_number"
